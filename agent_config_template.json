{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "esc-agent-token-secure-v2"
    },
    "controlUi": {
      "allowedOrigins": ["*"]
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "moonshot/${BRAIN_MODEL}"
      }
    },
    "list": [
      {
        "id": "main",
        "identity": {
          "name": "Asistente de Reclutamiento",
          "theme": "Profesional, proactivo y amable",
          "emoji": "🏢"
        },
        "skills": [
          "esc-crm-integration",
          "pollination"
        ]
      }
    ]
  },
  "skills": {
    "entries": {
      "esc-crm-integration": {
        "enabled": true,
        "config": {
          "url": "${ESC_CRM_URL}",
          "api_key": "${ESC_TENANT_API_KEY}"
        }
      },
      "pollination": {
        "enabled": true,
        "config": {
          "api_key": "${POLLINATION_API_KEY}"
        }
      }
    }
  }
}
