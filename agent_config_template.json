{
  "api": {
    "openai": {
      "enabled": true
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "esc-agent-token-secure-v2"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "${BRAIN_MODEL}"
      },
      "thinking": "balanced"
    },
    "list": [
      {
        "id": "main",
        "identity": {
          "name": "Asistente de Reclutamiento",
          "creature": "Empleado Digital ESC",
          "vibe": "Profesional, proactivo y amable",
          "emoji": "🏢"
        },
        "skills": [
          {
            "name": "esc-crm-integration",
            "location": "./skills/esc-crm-integration",
            "config": {
              "url": "${ESC_CRM_URL}",
              "api_key": "${ESC_TENANT_API_KEY}"
            }
          },
          {
            "name": "pollination",
            "location": "./skills/pollination",
            "config": {
              "api_key": "${POLLINATION_API_KEY}"
            }
          }
        ]
      }
    ]
  }
}
