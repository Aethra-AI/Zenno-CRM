{
  "api": {
    "enabled": true
  },
  "gateway": {
    "bind": "0.0.0.0",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "esc-agent-token-secure-v2"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "${BRAIN_MODEL}"
      }
    },
    "list": [
      {
        "id": "main",
        "identity": {
          "name": "Asistente de Reclutamiento",
          "theme": "Profesional, proactivo y amable",
          "emoji": "🏢"
        },
        "skills": [
          "esc-crm-integration",
          "pollination"
        ],
        "config": {
          "esc-crm-integration": {
            "url": "${ESC_CRM_URL}",
            "api_key": "${ESC_TENANT_API_KEY}"
          },
          "pollination": {
            "api_key": "${POLLINATION_API_KEY}"
          }
        }
      }
    ]
  }
}
