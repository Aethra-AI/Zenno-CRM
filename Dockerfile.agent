# Dockerfile para Instancias de Clawdbot ESC
# Propiedad de ESC (Expertos en Selección y Contratación)

FROM node:22-slim

# Instalar dependencias para Clawdbot y Playwright (necesario para WhatsApp)
RUN apt-get update && apt-get install -y \
    git \
    python3 \
    python3-pip \
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpangocairo-1.0-0 \
    libpango-1.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Crear directorio de la app
WORKDIR /app

# Instalar OpenClaw localmente para evitar problemas de PATH
RUN npm install openclaw

# Copiar archivos base
COPY agent_config_template.json /app/config.json
COPY access_template.json /app/access.json
COPY skills/ /app/skills/
COPY requirements_agent.txt /app/

# Instalar dependencias Python de las skills
RUN pip3 install --break-system-packages -r requirements_agent.txt

# Directorio para persistencia (Memoria y Sesiones)
RUN mkdir -p /app/memory /app/data /app/.openclaw /var/tmp/openclaw-compile-cache
VOLUME ["/app/memory", "/app/data"]

# Configuración del Gateway
ENV OPENCLAW_CONFIG_PATH=/app/config.json
ENV HOME=/app

# Exponer puerto para el Gateway de OpenClaw
EXPOSE 18789

# Comando de arranque: primero intenta corregir la config y luego arranca el gateway
CMD ["/bin/sh", "-c", "mkdir -p /app/.openclaw && cp /app/access.json /app/.openclaw/access.json && ./node_modules/.bin/openclaw doctor --fix && ./node_modules/.bin/openclaw gateway run"]
